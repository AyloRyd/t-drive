    "drizzle-orm": "^0.45.1",
    "lucide-react": "^0.576.0",
    "mysql2": "^3.18.2",
    "next": "^16.1.6",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.4",
    "@tailwindcss/postcss": "^4.2.1",
